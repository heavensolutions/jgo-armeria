# JGO Armeria - CPanel Passenger config
# This enables Python app via Phusion Passenger for CPanel

# Passenger config (auto-generated by CPanel's "Setup Python App")
# Usually CPanel generates this, but we provide a fallback:

PassengerEnabled On
PassengerAppRoot /home/site/jgo.lucasfuentes.com
PassengerBaseURI /
PassengerPython /home/site/virtualenvs/jgo-armeria/bin/python3
PassengerAppLogFile /home/site/jgo-armeria-log/error.log
PassengerFriendlyErrorPages off

# Large file upload support
LimitRequestBody 52428800

# Deny access to sensitive files
<FilesMatch "\.(env|pyc|md|txt)$">
    Require all denied
</FilesMatch>
